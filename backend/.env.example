# ─── Shopify Custom App ──────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here

# ─── Microsoft Outlook Email ─────────────────────────────────────────────────
OUTLOOK_EMAIL=your-email@example.com
OUTLOOK_APP_PASSWORD=your_app_password_here

# ─── Internal email (BCC on every invoice sent) ──────────────────────────────
INTERNAL_BCC_EMAIL=internal@example.com

# ─── Store details (used in PDF invoice) ─────────────────────────────────────
STORE_NAME=Your Store Name
STORE_ABN=XX XXX XXX XXX
STORE_EMAIL=store@example.com
STORE_PHONE=XXXX XXX XXX
STORE_ADDRESS=Your Store Address

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production